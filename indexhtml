<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>生日快乐</title>
    <style>
        *{margin:0;padding:0;}
        body{
            width:100%;
            height:100%;
            background:#000;
            overflow:hidden;
        }
    </style>
</head>
<body>

<!-- 粒子动画画布 -->
<canvas class="canvas" style="width:100%;height:100vh;"></canvas>

<!-- 你的动画JS -->
<script src="index.js"></script>

<!-- 音乐：用JS方式加载，绝对不影响动画 -->
<script>
// 点击播放生日快乐歌（不破坏HTML结构，绝不冲突）
document.addEventListener("click", function(){
  let audio = new Audio("HappyBirthday.mp3");
  audio.loop = true;
  audio.volume = 0.7;
  audio.play().catch(()=>{});
});
</script>

</body>
</html>